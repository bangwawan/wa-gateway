# ===========================
# Server
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# Database MySQL
# ===========================
DB_HOST="localhost"
DB_USER="root"
DB_PASSWORD="[PASSWORD]"
DB_DATABASE="wa_gateway"
DB_PORT=3306

DATABASE_URL="mysql://root:[PASSWORD]@localhost:3306/wa_gateway"

# ===========================
# JWT Authentication
# ===========================
JWT_SECRET="ganti_dengan_secret_yang_kuat_minimal_32_karakter"
JWT_EXPIRES_IN="7d"

# ===========================
# API Key (untuk akses internal / third-party)
# ===========================
# Bisa multiple, pisahkan dengan koma
API_KEYS="key_rahasia_1,key_rahasia_2"

# ===========================
# WhatsApp Session
# ===========================
WA_SESSION_PATH="./wa-session"

# ===========================
# Queue (Redis - opsional, kosongkan untuk in-memory)
# ===========================
REDIS_HOST=
REDIS_PORT=6379

# ===========================
# Logging
# ===========================
LOG_LEVEL=info
LOG_DIR=./logs
